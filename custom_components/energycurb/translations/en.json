{
  "config": {
    "step": {
      "user": {
        "title": "Curb listener",
        "description": "Bind an HTTP listener for incoming Curb hub data. Point `border.prod.energycurb.com` at this Home Assistant host via DNS (or use a reverse proxy), then set the hub to POST to `http://HA_HOST:PORT/v3/samples/SERIAL`.",
        "data": {
          "host": "Bind host",
          "port": "Bind port"
        }
      }
    },
    "abort": {
      "already_configured": "A Curb listener is already configured on this host:port."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Select a Curb hub",
        "description": "Pick the hub whose circuits you want to configure.",
        "data": {
          "serial": "Hub serial"
        }
      },
      "circuits": {
        "title": "Circuit configuration - {serial}",
        "description": "Each group below is one physical circuit position (A1–C6 on a standard 4-chip hub, A1–B6 on a Lite 2-chip hub). Assign a name, current clamp, voltage, and whether the clamp is inverted. The hub-config.json served at /v3/hub_config/{serial} is generated from these values.",
        "data": {
          "sample_period_s": "Power update interval",
          "extra_sensors": "Extra electrical sensors"
        },
        "data_description": {
          "sample_period_s": "How often the power sensors refresh in HA. '1 second' is live (raw 1 Hz stream); '1 minute' refreshes from the hub's per-minute aggregate (~60x less recorder load). Energy totals always accumulate per minute regardless of this setting.",
          "extra_sensors": "Adds per-circuit current / power factor / reactive power and per-phase voltage / frequency entities. Triples the entity count, so leave off unless you actually need them."
        },
        "sections": {
          "c1":  {"name": "A1", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c2":  {"name": "A2", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c3":  {"name": "A3", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c4":  {"name": "A4", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c5":  {"name": "A5", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c6":  {"name": "A6", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c7":  {"name": "B1", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c8":  {"name": "B2", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c9":  {"name": "B3", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c10": {"name": "B4", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c11": {"name": "B5", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c12": {"name": "B6", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c13": {"name": "C1", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c14": {"name": "C2", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
          "c15": {"name": "C3", "data": {"name": "Name", "clamp": "Clamp", "voltage": "Voltage", "inverted": "Inverted", "bidirectional": "Bi-directional"}},
